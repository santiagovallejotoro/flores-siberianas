# Public site URL (no trailing slash). Used for metadataBase, sitemap, robots, canonical/OG URLs.
# Production: https://www.floressiberianas.com
NEXT_PUBLIC_SITE_URL=https://www.floressiberianas.com

# Supabase - get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Supabase service role key - server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
